FROM node:22-slim

RUN apt-get update && apt-get install -y \
    build-essential \
    python3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

# Source is mounted as volume for hot reload
ENV NODE_ENV=development
ENV SERVER_PORT=3001
ENV VITE_PORT=5173
ENV HOST=0.0.0.0

EXPOSE 3001 5173

CMD ["npm", "run", "dev"]
